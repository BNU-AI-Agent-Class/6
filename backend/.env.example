# 复制本文件为 .env 后再填写；不要把 .env 或真实密钥提交到 Git。

# 必填：OpenRouter 密钥（这里只保留占位符）
OPENROUTER_API_KEY=replace_with_your_openrouter_key

# 允许本地前端与 GitHub Pages 跨域访问
CORS_ORIGINS=http://localhost:5500,https://bnu-ai-agent-class.github.io

# 建议显式固定模型服务配置
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=deepseek/deepseek-v4-flash

# 可选：单独指定出口安全复核模型；留空则使用 LLM_MODEL，但仍是独立请求。
SAFETY_REVIEW_MODEL=

# PORT 由 Render 自动注入，不要在生产环境手工设置。
